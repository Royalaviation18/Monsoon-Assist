# ─── RainReady Backend Environment Variables ───────────────────────────────────
# Copy this file to .env and fill in your values.

# Gemini API key from https://aistudio.google.com/
GEMINI_API_KEY=

# Gemini model to use (optional — defaults to gemini-1.5-flash-latest)
GEMINI_MODEL=gemini-1.5-flash-latest

# MongoDB connection string (use MongoDB Atlas URI for production)
MONGODB_URI=mongodb://127.0.0.1:27017/rainready

# Port for the Express server (Render sets this automatically)
PORT=3001

# Set to 'production' on your host
NODE_ENV=development

# Frontend origin for CORS (your Vercel deployment URL)
ALLOWED_ORIGIN=http://localhost:5174
